<UserControl x:Class="WpfPersonne.Views.ListSelectchaussureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfPersonne.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition  Height="Auto"/>
            <RowDefinition  Height="*"/>
            <RowDefinition  Height="Auto"/>
        </Grid.RowDefinitions>
        <Label   Content="Sélectionnez votre chaussure à ajouter" />

        <ListBox Width="Auto"  Margin="5" Grid.Row="1"
        IsSynchronizedWithCurrentItem="True"        
       ItemsSource="{Binding ChaussuresViewSource}">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <WrapPanel>
                        <TextBlock Margin="5"  Text="{Binding Path=Id_chaussure}" />
                        <TextBlock Margin="5" Text="{Binding Path=Code_genreChaussure}"/>
                        <TextBlock Margin="5"  Text="{Binding Path=Code_typeChaussure}"/>
                        <TextBlock Margin="5"  Text="{Binding Path=Prix}"/>
                        <TextBlock Margin="5"  Text="{Binding Path=Taille}"/>

                    </WrapPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel  Orientation="Horizontal" Grid.Row="2" Margin="10">
            <Button Margin="5" Command="{Binding AddSelectChaussureCommand}">AddSelect</Button>
            <Button Margin="5" Command="{Binding CancelSelectChaussureCommand}">CancelSelect</Button>
        </StackPanel >
    </Grid>

</UserControl>
