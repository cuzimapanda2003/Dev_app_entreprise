<UserControl x:Class="WpfPersonne.Views.PersonneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfPersonne.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200" >
    <Grid ShowGridLines="True">
        <!--5 colonnes 0 et 1 et 2 pour autres listes au choix-->
        <!--colonne 3 liste de navigation principale-->
        <!--colonne 4  tout le reste divisée dans un autre grid-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <local:ListSelectchaussureView Grid.Column="0" Visibility="{Binding VisibilityListSelectChaussure}" >

        </local:ListSelectchaussureView>

        <!-- liste principale-->
        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!--entete de liste principale-->
            <WrapPanel Grid.Row="0">
                <Label Content="Nom Famille" Margin="10,0,0,0" />
                <Label Content="Prenom"  Margin="5,0,0,0" />
                <Label Content="Age" Margin="10,0,0,0"/>
            </WrapPanel>
            <!--données liste principale-->
            <ListBox Grid.Row="1" ItemsSource="{Binding PersonnesViewSource}" Margin="10, 5, 10, 0" MinHeight="30" IsSynchronizedWithCurrentItem="True" IsEnabled="{Binding IsEnabledListNavigation}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <WrapPanel>
                            <TextBlock Text="{Binding Id_Personne}" MinWidth="10"/>
                            <TextBlock Text="{Binding NomFamille}" MinWidth="60"/>
                            <TextBlock Text="{Binding Prenom}" MinWidth="60" Margin="15,0,0,0"/>
                            <TextBlock Text="{Binding Age,Mode=TwoWay}" Margin="10,0,0,0"/>
                        </WrapPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!--ecran du use case-->
        <Grid ShowGridLines="True" Grid.Column="4" Background="#FFBFCDDB" HorizontalAlignment="Stretch">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto"  />
                <ColumnDefinition Width="Auto"  />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="20"/>
            </Grid.RowDefinitions>

            <!-- Liaison à l'objet personne  -->
            <StackPanel Name="topleft" Grid.Row="0" Grid.Column="0" Margin="5">
                <WrapPanel Margin="0, 10, 0, 0">
                    <Label Content="Id: "/>
                    <TextBlock Margin="0, 5, 0, 5" Text="{Binding PersonnesViewSource.CurrentItem.Id_Personne}" Height="20" Width="150"/>
                </WrapPanel>
                <WrapPanel Margin="0, 10, 0, 0">
                    <Label Content="Nom de Famille: "/>
                    <TextBox IsEnabled="{Binding IsEnabled}" Margin="0, 5, 0, 5" Text="{Binding PersonnesViewSource.CurrentItem.NomFamille, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="150"/>
                </WrapPanel>
                <WrapPanel Margin="0, 10, 0, 0">
                    <Label Content="Prénom: "/>
                    <TextBox IsReadOnly="{Binding IsReadOnly}" Margin="40, 5, 0, 5" Text="{Binding PersonnesViewSource.CurrentItem.Prenom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="150"/>
                </WrapPanel>
                <WrapPanel Margin="0, 10, 0, 0">
                    <Label Content="Âge: "/>
                    <TextBox IsEnabled="{Binding IsEnabled}" Margin="60, 5, 0, 5" Text="{Binding PersonnesViewSource.CurrentItem.Age, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="150"/>
                </WrapPanel>
                <WrapPanel>
                    <CheckBox Margin="0,6,5,5"
                        IsChecked="{Binding PersonnesViewSource.CurrentItem.Actif}" Content="Actif"/>
                    <Label Content="byte : "/>
                    <TextBox Text="{Binding PersonnesViewSource.CurrentItem.Actif, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="10" />
                </WrapPanel>
                <WrapPanel Margin="0, 10, 0, 5">
                    <Label Content="Date création"/>
                    <DatePicker SelectedDate="{Binding PersonnesViewSource.CurrentItem.Date_CreationBidon, Mode=TwoWay}" VerticalAlignment="Center" />
                </WrapPanel>
                <WrapPanel Margin="0, 3, 0, 5">
                    <Label Content="total inventaire"/>
                    <TextBlock Text="{Binding PersonnesViewSource.CurrentItem.Total_Ventes,StringFormat='{}{0:C}', Mode=TwoWay}" VerticalAlignment="Center" />
                </WrapPanel>
            </StackPanel>

            <!--partie centrale haut lien 1-1-->
            <StackPanel Margin="20,20,0,10" Name="topcenter" Grid.Row="0" Grid.Column="1">
                <Border BorderThickness="2" BorderBrush="Gray">
                    <StackPanel Margin="0,0,0,0">
                        <WrapPanel Margin="0, 10, 0, 0">
                            <Label Content="Province: "/>
                            <TextBox IsEnabled="{Binding IsEnabled}" Margin="20, 5, 0, 5" Text="{Binding PersonnesViewSource.CurrentItem.Code_Province, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="50"/>
                            <ComboBox Name="CBOXprovince"
                                      ItemsSource="{Binding ProvincesViewSource}"
                                      DisplayMemberPath="Description"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding PersonnesViewSource.CurrentItem.Code_Province, Mode=TwoWay}"
                                      HorizontalAlignment="Left" Height="23" Margin="10,3,3,3" VerticalAlignment="Center" Width="120"/>
                        </WrapPanel>
                        <WrapPanel Margin="0, 10, 0, 0">
                            <Label Content="Profession: "/>
                            <TextBox IsEnabled="{Binding IsEnabled}" Margin="10, 5, 0, 5" Text="{Binding PersonnesViewSource.CurrentItem.Id_Profession, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="50"/>
                            <ComboBox Name="CBOXprofession"
                                      HorizontalAlignment="Left"
                                      Height="23" Margin="10,3,3,3"
                                      VerticalAlignment="Center"
                                      Width="120"
                                      ItemsSource="{Binding ProfessionsViewSource}"
                                      DisplayMemberPath="Description"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding PersonnesViewSource.CurrentItem.Id_Profession, Mode=TwoWay}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!--bouton add edit delete save cancel parent-->
            <StackPanel Grid.Column="2" Margin="10,10,10,5">
                <Button Margin="0,5,5,5" Command="{Binding AddPersonneCommand}" Width="75">Add</Button>
                <Button Margin="0,5,5,5" Command="{Binding EditPersonneCommand}" Content="Edit" Width="75"/>
                <Button Margin="0,5,5,5" Command="{Binding DeletePersonneCommand}" Content="Delete" Width="75"/>
                <Button Margin="0,5,5,5" Command="{Binding SavePersonneCommand}" Content="Save" Width="75"/>
                <Button Margin="0,5,5,5" Command="{Binding CancelPersonneCommand}" Content="Cancel" Width="75"/>
            </StackPanel>

            <!--bouton add delete enfant droite du grid-->
            <StackPanel Name="buttomRight" Grid.Row="2" Grid.Column="2" Margin="10,10,10,5">
                <Button Command="{Binding AddEnfantCommand}" Name="btnAddEnfant" Margin="0,5,5,5">Add Enfant</Button>
                <!-- CORRECTION : ajout du CommandParameter -->
                <Button Command="{Binding DeleteEnfantCommand}" Name="btnDeleteEnfant" Margin="0,5,5,5"
                        CommandParameter="{Binding PersonnesViewSource.CurrentItem.PersonneChaussures.CurrentItem}">
                    Delete Enfant
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal">
                <Label Content="Total:" HorizontalAlignment="Left" Margin="10" VerticalAlignment="Center" Style="{StaticResource LabelText}"/>
                <TextBox IsEnabled="false" HorizontalAlignment="Left" Height="23" Margin="3" Width="100"/>
            </StackPanel>

            <DataGrid x:Name="DataGrid" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
                      IsSynchronizedWithCurrentItem="true"
                      ItemsSource="{Binding PersonnesViewSource.CurrentItem.PersonneChaussures}"
                      AutoGenerateColumns="False" EnableRowVirtualization="True" CanUserAddRows="False"
                      Margin="5,5,5,5" Width="Auto"
                      IsReadOnly="{Binding IsReadOnly}">

                <DataGrid.RowBackground>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFDAE3E4" Offset="0.49"/>
                        <GradientStop Color="#FFE6F0F1" Offset="0.5"/>
                    </LinearGradientBrush>
                </DataGrid.RowBackground>

                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="idpersonnechaussure"
                                Header="id personneChaussure" Width="SizeToHeader"
                                Binding="{Binding Id_personneChaussure}" IsReadOnly="True"/>

                    <DataGridTextColumn x:Name="idpersonne"
                                Header="id personne" Width="SizeToHeader"
                                Binding="{Binding Id_personne}" IsReadOnly="True"/>

                    <DataGridTextColumn x:Name="idchaussure"
                                Header="id chaussure" Width="SizeToHeader"
                                Binding="{Binding Id_chaussure}" IsReadOnly="True"/>

                    <DataGridTextColumn x:Name="descgenreColumn"
                                Header="Genre" Width="SizeToHeader"
                                Binding="{Binding Chaussure.GenreChaussure.Description}"/>

                    <DataGridTextColumn Binding="{Binding Chaussure.TypeChaussure.Description}"
                                Header="Type chaussure" Width="SizeToHeader"/>

                    <DataGridTextColumn x:Name="qte"
                                Binding="{Binding Qte_stock, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                Header="Qte stock" Width="SizeToHeader"/>

                    <DataGridTextColumn x:Name="prixvente"
                                Binding="{Binding Prix_vente, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                Header="Prix vente" Width="SizeToHeader"/>

                    <!-- AJOUT : colonne poubelle dans le DataGrid -->
                    <DataGridTemplateColumn Header="Supprimer">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑"
                                        Command="{Binding DataContext.DeleteEnfantCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Padding="5"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

        </Grid>

    </Grid>
</UserControl>
