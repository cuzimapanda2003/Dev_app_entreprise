<UserControl x:Class="WpfPersonne.Views.PersonneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfPersonne.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200" >
    <Grid ShowGridLines="True">
        <!--5 colonnes 0 et 1 et 2 pour autres listes au choix-->
        <!--colonne 3 liste de navigation principale-->
        <!--colonne 4  tout le reste divisée dans un autre grid-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!--<local:ListSelectchaussureView Grid.Column="0" Visibility="{Binding VisibilityListSelectChaussure}" ></local:ListSelectchaussureView>-->
        <!--<local:ListSelectProdView Grid.Column="1" Visibility="{Binding VisibilitySelectProduit}" ></local:ListSelectProdView>-->

        <!-- liste principale-->
        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>
            <!--entete de liste principale-->
            <WrapPanel Grid.Row="0">
                <Label Content="Nom Famille" Margin="10,0,0,0" />
                <Label Content="Prenom"  Margin="5,0,0,0" />
                <Label Content="Age" Margin="10,0,0,0"/>
            </WrapPanel>
            <!--données liste principale-->
            <ListBox Grid.Row="1" ItemsSource="{Binding Personnes}" Margin="10, 5, 10, 0"  MinHeight="30"
                    IsSynchronizedWithCurrentItem="True"   
                     SelectedItem="{Binding SelectedPersonne, Mode=TwoWay}"          
                  >

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <WrapPanel>
                            <TextBlock Text="{Binding Id_Personne}" MinWidth="10"/>
                            <TextBlock Text="{Binding NomFamille}" MinWidth="60"/>
                            <TextBlock Text="{Binding Prenom}" MinWidth="60" Margin="15,0,0,0"/>
                            <TextBlock Text="{Binding Age,Mode=TwoWay}" Margin= "10,0,0,0"/>
                            <!--meme two way si refresh ne change pas en haut-->
                        </WrapPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        <!--ecran du use case-->
        <Grid ShowGridLines="True" Grid.Column="4"  Background="#FFBFCDDB" HorizontalAlignment="Stretch">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto"  />
                <ColumnDefinition Width="Auto"  />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition   Height="4*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition  Height="3*"/>
                <RowDefinition  Height="20"/>
            </Grid.RowDefinitions>
            <!--liste de navigation principale a gauche-->

            <!-- Liaison à l'objet personne  -->
            <StackPanel   Name="topleft"   Grid.Row="0"  Grid.Column="0"  Margin="5"  >
                <WrapPanel Margin="0, 10, 0, 0">
                    <Label Content="Id: "/>
                    <TextBlock Margin="0, 5, 0, 5" Text="{Binding SelectedPersonne.Id_Personne}" Height="20" Width="150"/>
                </WrapPanel>
                <WrapPanel Margin="0, 10, 0, 0">
                    <Label Content="Nom de Famille: "/>
                    <TextBox  Margin="0, 5, 0, 5" Text="{Binding SelectedPersonne.NomFamille, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="150"/>
                </WrapPanel>
                <WrapPanel Margin="0, 10, 0, 0">
                    <Label Content="Prénom: "/>
                    <TextBox   Margin="40, 5, 0, 5" Text="{Binding SelectedPersonne.Prenom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="150"/>
                </WrapPanel>
                <WrapPanel Margin="0, 10, 0, 0">
                    <Label Content="Âge: "/>
                    <TextBox   Margin="60, 5, 0, 5" Text="{Binding SelectedPersonne.Age, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="150"/>
                </WrapPanel>

                <WrapPanel>
                    <CheckBox Margin="0,6,5,5"
                        
                        IsChecked ="{Binding SelectedPersonne.Actif}" Content="Actif" 
                        />
                    <Label Content="byte : "/>
                    <TextBox  Text="{Binding SelectedPersonne.Actif, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="10" />
                </WrapPanel>

                <WrapPanel Margin="0, 10, 0, 5">
                    <Label Content="Date création"/>
                    <DatePicker   SelectedDate="{Binding SelectedPersonne.Date_CreationBidon, Mode=TwoWay}" VerticalAlignment="Center" />
                </WrapPanel>
                <WrapPanel Margin="0, 3, 0, 5">
                    <Label Content="total inventaire"/>
                    <TextBlock Text="{Binding SelectedPersonne.Total_Ventes,StringFormat='{}{0:C}', Mode=TwoWay}" VerticalAlignment="Center" />
                </WrapPanel>

            </StackPanel>

            <!--partie centrale haut lien 1-1-->
            <StackPanel Margin="20,20,0,10" Name="topcenter"  
           Grid.Row="0"  Grid.Column="1"  
                     >
                <Border  BorderThickness="2" BorderBrush="Gray">
                    <StackPanel    Margin="0,0,0,0">
                        <WrapPanel Margin="0, 10, 0, 0">
                            <Label Content="Province: "/>
                            <TextBox  Margin="20, 5, 0, 5" Text="{Binding SelectedPersonne.Code_Province, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="50"/>
                            <ComboBox Name="CBOXprovince"   
                          
                         
   
                        HorizontalAlignment="Left" Height="23" Margin="10,3,3,3"   VerticalAlignment="Center" Width="120"/>
                        </WrapPanel>
                        <!--SelectedItem="{Binding PersonnesViewSource.CurrentItem.Province, Mode=TwoWay}"-->
                        <WrapPanel Margin="0, 10, 0, 0">
                            <Label Content="Profession: "/>
                            <TextBox   Margin="10, 5, 0, 5" Text="{Binding SelectedPersonne.Id_Profession, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20" Width="50"/>
                            <ComboBox Name="CBOXprofession"  
                          
                          
                            
   
         HorizontalAlignment="Left" Height="23" Margin="10,3,3,3"   VerticalAlignment="Center" Width="120"/>

                        </WrapPanel>
                    </StackPanel>
                </Border>
                <!--bouton nav-->

            </StackPanel>
            <!--fin lien 1-1-->
            <!--bouton add edit delete save cancel parent-->
            <StackPanel   Grid.Column="2" Margin="10,10,10,5" >

                <Button Margin="0,5,5,5" Command="{Binding AddPersonneCommand}" Width  ="75" >Add</Button>
                <Button   Margin="0,5,5,5"  Content="Edit"  Width  ="75"/>
                <Button   Margin="0,5,5,5" Command="{Binding DeletePersonneCommand}" Content="Delete"  Width  ="75"/>

                <Button   Margin="0,5,5,5"  Content="Save" Width  ="75" />
                <Button   Margin="0,5,5,5"  Content="Cancel" Width  ="75" />
            </StackPanel>

            <!--bouton add edit delete save cancel enfant droite du grid-->
            <StackPanel Name="buttomRight" Grid.Row="2" Grid.Column="2" Margin="10,10,10,5" >


                <Button Name="btnAddEnfant" Margin="0,5,5,5" 
                  >Add Enfant</Button>
                <Button Name="btnDeleteEnfant"  Margin="0,5,5,5" 
                    >Delete Enfant</Button>


            </StackPanel>
           
           
            <StackPanel Grid.Column="1"  Grid.Row="3" Orientation="Horizontal">
                <Label  Content="Total:"  HorizontalAlignment="Left" Margin="10" VerticalAlignment="Center" Style="{StaticResource LabelText}"/>
                <TextBox  IsEnabled="false" HorizontalAlignment="Left" Height="23" Margin="3" Width="100" />


            </StackPanel>
        </Grid>







    </Grid>
</UserControl>
