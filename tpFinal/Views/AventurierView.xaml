<!-- AventurierView.xaml -->
<UserControl
    x:Class="tpFinal.Views.AventurierView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:tpFinal.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <Grid ShowGridLines="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <local:ListSelectEquipementView Grid.Column="0"
                                        Visibility="{Binding VisibilityListSelectEquipement}">
        </local:ListSelectEquipementView>

        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <WrapPanel Grid.Row="0">
                <Label Margin="10,0,0,0" Content="Id" />
                <Label Margin="5,0,0,0" Content="Nom" />
                <Label Margin="10,0,0,0" Content="Solde Or" />
            </WrapPanel>

            <ListBox Grid.Row="1" MinHeight="30" Margin="10,5,10,0"
                     ItemsSource="{Binding AventuriersViewSource}"
                     IsSynchronizedWithCurrentItem="True"
                     IsEnabled="{Binding IsEnabledListNavigation}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <WrapPanel>
                            <TextBlock MinWidth="10" Text="{Binding id}" />
                            <TextBlock MinWidth="60" Text="{Binding nom}" />
                            <TextBlock MinWidth="60" Margin="15,0,0,0" Text="{Binding solde_or}" />
                        </WrapPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Column="4" Background="#FFBFCDDB" ShowGridLines="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="4*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
                <RowDefinition Height="20" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                <WrapPanel Margin="0,10,0,0">
                    <Label Content="Id: " />
                    <TextBlock Width="150" Height="20" Margin="0,5,0,5"
                               Text="{Binding AventuriersViewSource.CurrentItem.id}" />
                </WrapPanel>
                <WrapPanel Margin="0,10,0,0">
                    <Label Content="Nom: " />
                    <TextBox Width="150" Height="20" Margin="40,5,0,5"
                             IsEnabled="{Binding IsEnabled}"
                             Text="{Binding AventuriersViewSource.CurrentItem.nom,
                                    Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </WrapPanel>
                <WrapPanel Margin="0,10,0,0">
                    <Label Content="Niveau: " />
                    <TextBox Width="150" Height="20" Margin="60,5,0,5"
                             IsEnabled="{Binding IsEnabled}"
                             Text="{Binding AventuriersViewSource.CurrentItem.niveau,
                                    Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </WrapPanel>
                <WrapPanel Margin="0,10,0,5">
                    <Label Content="Date inscription" />
                    <DatePicker IsEnabled="{Binding IsEnabled}"
                                SelectedDate="{Binding AventuriersViewSource.CurrentItem.DateInscription,
                                               Mode=TwoWay}" />
                </WrapPanel>
                <WrapPanel Margin="0,3,0,5">
                    <Label Content="Solde en or" />
                    <TextBox Width="50" Height="20" Margin="20,5,0,5"
                             IsEnabled="{Binding IsEnabled}"
                             Text="{Binding AventuriersViewSource.CurrentItem.solde_or,
                                    Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </WrapPanel>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Margin="20,20,0,10">
                <Border BorderBrush="Gray" BorderThickness="2">
                    <StackPanel>
                        <WrapPanel Margin="0,10,0,0">
                            <Label Content="Metier: " />
                            <TextBox Width="50" Height="20" Margin="20,5,0,5"
                                     IsEnabled="{Binding IsEnabled}"
                                     Text="{Binding AventuriersViewSource.CurrentItem.id_metier,
                                            Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox Width="120" Height="23" Margin="10,3,3,3"
                                      IsEnabled="{Binding IsEnabled}"
                                      ItemsSource="{Binding MetiersViewSource}"
                                      DisplayMemberPath="name"
                                      SelectedValuePath="id"
                                      SelectedValue="{Binding AventuriersViewSource.CurrentItem.id_metier,
                                                      Mode=TwoWay}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="10,10,10,5">
                <Button Width="75" Margin="0,5,5,5" Content="Add"
                        Command="{Binding AddAventurierCommand}" />
                <Button Width="75" Margin="0,5,5,5" Content="Edit"
                        Command="{Binding EditAventurierCommand}" />
                <Button Width="75" Margin="0,5,5,5" Content="Delete"
                        Command="{Binding DeleteAventurierCommand}" />
                <Button Width="75" Margin="0,5,5,5" Content="Save"
                        Command="{Binding SaveAventurierCommand}" />
                <Button Width="75" Margin="0,5,5,5" Content="Cancel"
                        Command="{Binding CancelAventurierCommand}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="2" Margin="10,10,10,5">
                <Button Margin="0,5,5,5" Content="Add Enfant"
                        Command="{Binding AddEquipementCommand}" />
                <Button Margin="0,5,5,5" Content="Delete Enfant"
                        Command="{Binding DeleteEquipementCommand}"
                        CommandParameter="{Binding AventuriersViewSource.CurrentItem.AventurierEquipements.CurrentItem}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                <Label Margin="10" Content="Total:" />
                <TextBox Width="100" Height="23" Margin="3" IsEnabled="False" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                <DataGrid
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    Width="Auto"
                    Margin="5"
                    IsSynchronizedWithCurrentItem="True"
                    IsReadOnly="{Binding IsReadOnly}"
                    ItemsSource="{Binding AventuriersViewSource.CurrentItem.AventurierEquipements}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="id Av.Eq"
                                            Binding="{Binding id}" IsReadOnly="True" />
                        <DataGridTextColumn Header="id Aventurier"
                                            Binding="{Binding id_aventurier}" IsReadOnly="True" />
                        <DataGridTextColumn Header="id Equipement"
                                            Binding="{Binding id_equipement}" IsReadOnly="True" />
                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Equipement.description}" />
                        <DataGridTextColumn Header="Type Objet"
                                            Binding="{Binding Equipement.TypeObjet.description}" />
                        <DataGridTextColumn Header="Qte Totale"
                                            Binding="{Binding quantite_totale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="Qte Active"
                                            Binding="{Binding quantite_active, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="Prix Achat"
                                            Binding="{Binding prix_achat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="Depense"
                                            Binding="{Binding Depense}" IsReadOnly="True" />

                        <DataGridTemplateColumn Header="Supprimer">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑"
                                            Command="{Binding DataContext.DeleteEquipementCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,10,10,5" Name="nav"
                        Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                <Button Name="btnFirst" Content="|◄" Style="{StaticResource NavButton}"
                        Command="{Binding FirstAventurierCommand}" />
                <Button Name="btnPrev" Content="◄" Style="{StaticResource NavButton}"
                        Command="{Binding PrevAventurierCommand}" />
                <Button Name="btnNext" Content="►" Style="{StaticResource NavButton}"
                        Command="{Binding NextAventurierCommand}" />
                <Button Name="btnLast" Content="►|" Style="{StaticResource NavButton}"
                        Command="{Binding LastAventurierCommand}" />
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>