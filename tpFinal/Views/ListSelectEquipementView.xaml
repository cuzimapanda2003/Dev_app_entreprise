<UserControl x:Class="tpFinal.Views.ListSelectEquipementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tpFinal.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Content="Sélectionnez un équipement à ajouter" />

        <ListBox Width="Auto" Margin="5" Grid.Row="1"
                 IsSynchronizedWithCurrentItem="True"
                 ItemsSource="{Binding EquipementsViewSource}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <WrapPanel>
                        <TextBlock Margin="5" Text="{Binding Path=id}"/>
                        <TextBlock Margin="5" Text="{Binding Path=description}"/>
                        <TextBlock Margin="5" Text="{Binding Path=code_type_objet}"/>
                        <TextBlock Margin="5" Text="{Binding Path=quantite}"/>
                        <TextBlock Margin="5" Text="{Binding Path=prix_unitaire}"/>
                    </WrapPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="10">
            <Button Margin="5" Command="{Binding AddSelectEquipementCommand}">AddSelect</Button>
            <Button Margin="5" Command="{Binding CancelSelectEquipementCommand}">CancelSelect</Button>
        </StackPanel>

    </Grid>
</UserControl>