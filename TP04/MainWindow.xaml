<Window x:Class="TP02.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TP02"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="1200"
        xmlns:viewmodels="clr-namespace:TP02.ViewsModels"
        xmlns:views="clr-namespace:TP02.Views"
        >

    <Window.Resources>

        <DataTemplate x:Name="ClintView" DataType="{x:Type  viewmodels:ClientViewModel}">
            <views:ClientView/>
        </DataTemplate>

        <DataTemplate x:Name="Acceuil" DataType="{x:Type  viewmodels:AcceuilViewModel}">
            <views:AcceuilView/>
        </DataTemplate>


    </Window.Resources>

    <Grid ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Grid Grid.Row="0" ShowGridLines="true">
            <DockPanel>
                <Menu DockPanel.Dock="top">
                    <MenuItem Header="Acceuil" Command="{Binding AcceuilCommand}"/>
                    <MenuItem Header="Client" Command="{Binding ClientCommand}"/>
                </Menu>
            </DockPanel>

        </Grid>

        <Grid Grid.Row="1" ShowGridLines="true">
            <ContentControl   Grid.Row="1" Content="{Binding CurrentViewModel}" />
        </Grid>
        
        
        

    </Grid>

</Window>
