<UserControl x:Class="TP02.Views.ClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TP02.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             Background="LightGray" Width="1039"
             >
    <Grid ShowGridLines="true" >



        <Grid ShowGridLines="True"  Grid.Row="0">
            <!--5 colonnes 0 et 1 et 2 pour autres listes au choix-->
            <!--colonne 3 liste de navigation principale-->
            <!--colonne 4  tout le reste divisée dans un autre grid-->

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto" MinWidth="300" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>



            <!-- liste principale-->
            <Grid Grid.Column="3" Background="Beige">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--colonne fixe a 300 vous pouvez y placer auto ou autre-->

                <!--données liste principale-->

                <ListBox ItemsSource="{Binding ClientsViewSource, Mode=TwoWay}" Margin="10, 5, 10, 0"  MinHeight="30"
                    IsSynchronizedWithCurrentItem="True" 
                         
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"

                     >
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <WrapPanel>
                                <!--<TextBlock Text="{Binding Name}"/>-->
                                <TextBlock Text="{Binding Id_client}" Width="30" />
                                <TextBlock Text="{Binding Nom}" Width="125"  Margin="5,0,0,0"/>
                                <TextBlock Text="{Binding Code_province}" Width="30" Margin= "5,0,0,0"/>
                                <TextBlock Text="{Binding Code_pays}" Width="30" Margin= "5,0,0,0"/>
                                <TextBlock Text="{Binding Solde, StringFormat={}{0:C}}" Margin= "5,0,0,0"/>
                            </WrapPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </Grid >

            <!--ecran du use case détail-->
            <Grid ShowGridLines="True" Grid.Column="4" Background="Azure"  HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto"  />
                    <ColumnDefinition Width="10"  />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Liaison à l'objet  détail -->
                <StackPanel Name="topleft" Grid.Row="0" Grid.Column="0" Margin="5">
                    <WrapPanel Margin="0, 10, 0, 0">
                        <Label Content="Id Client: "/>
                        <TextBlock  Margin="0, 5, 0, 5" Height="20" Width="150" Text="{Binding ClientsViewSource.CurrentItem.Id_client,Mode=OneWay}"/>
                    </WrapPanel>

                    <WrapPanel Margin="0, 10, 0, 0">
                        <Label Content="Nom: " Width="100"/>
                        <TextBox IsReadOnly="{Binding IsReadOnly}" Text="{Binding ClientsViewSource.CurrentItem.Nom,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0, 5, 0, 5" Height="20" Width="150"  />
                    </WrapPanel>
                    <WrapPanel Margin="0, 5, 0, 5">
                        <Label Content="Telephone: " Width="100"/>
                        <TextBox Margin="0, 5, 0, 5" Height="20" Width="150" IsEnabled="{Binding IsEnabled}" Text="{Binding ClientsViewSource.CurrentItem.Telephone,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                    </WrapPanel>
                    <WrapPanel Margin="0, 5, 0, 5">
                        <Label Content="Adresse: " Width="100"/>
                        <TextBox Margin="0, 5, 0, 5" Height="20" Width="150" IsEnabled="{Binding IsEnabled}" Text="{Binding ClientsViewSource.CurrentItem.Adresse,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                    </WrapPanel>


                    <!-- Adresse width au lieu de marge pour texbox -->
                    <WrapPanel Margin="0, 5, 0, 5">
                        <Label Content="Ville :" Width="100"/>
                        <TextBox IsEnabled="{Binding IsEnabled}" Text="{Binding ClientsViewSource.CurrentItem.Ville,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" Margin="0, 5, 0, 5" x:Name="TxtAdresse"  Height="20" Width="150"/>
                    </WrapPanel>



                    <WrapPanel Margin="0, 5, 0, 5">
                        <Label Content="Code Postal: " Width="100" />
                        <TextBox  Height="20" Width="150" IsEnabled="{Binding IsEnabled}" Text="{Binding ClientsViewSource.CurrentItem.Code_postal,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"/>
                    </WrapPanel>

                </StackPanel>

                <!--partie centrale haut lien 1-1-->
                <StackPanel Margin="20,20,0,10" Name="topcenter" Grid.Row="0" Grid.Column="1">
                    <Border BorderThickness="2" BorderBrush="Gray">
                        <StackPanel Margin="0,0,0,0">
                            <WrapPanel Margin="0, 10, 0, 0">
                                <Label Content="Province: "/>
                                <TextBox Margin="20, 5, 0, 5" Height="20" Width="50" Text="{Binding ClientsViewSource.CurrentItem.Code_province,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" IsEnabled="False"/>
                                <ComboBox IsEnabled="{Binding IsEnabled}" Name="CBOXprovince"
                                      ItemsSource="{Binding ProvincesViewSource}"
                                      HorizontalAlignment="Left" Height="23" Margin="10,3,3,3"
                                      VerticalAlignment="Center" Width="120"
                                      DisplayMemberPath="Nom"
                                      SelectedValuePath="Code_Province" 
                                      SelectedValue="{Binding ClientsViewSource.CurrentItem.Code_province, Mode=TwoWay}"/>
                            </WrapPanel>

                            <WrapPanel Margin="0, 10, 0, 0">
                                <Label Content="Pays: "/>
                                <TextBox Margin="10, 5, 0, 5" Height="20" Width="50" Text="{Binding ClientsViewSource.CurrentItem.Code_pays,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" IsEnabled="False"/>
                                <ComboBox IsEnabled="{Binding IsEnabled}" Name="CBOXpays"
                                      ItemsSource="{Binding PaysViewSource}"
                                      HorizontalAlignment="Left" Height="23" Margin="10,3,3,3"
                                      VerticalAlignment="Center" Width="120"
                                      DisplayMemberPath="Nom"
                                      SelectedValuePath="Code_Pays" 
                                      SelectedValue="{Binding ClientsViewSource.CurrentItem.Code_pays, Mode=TwoWay}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <WrapPanel Margin="0, 5, 0, 5">
                        <Label Content="Solde: " Width="100"/>
                        <TextBox Margin="0, 5, 0, 5" Height="20" Width="150" Text="{Binding ClientsViewSource.CurrentItem.Solde, StringFormat={}{0:C},Mode=OneWay}" IsEnabled="False"/>
                    </WrapPanel>

                </StackPanel>
                <!--fin lien 1-1-->

                <!--bouton add edit delete save cancel parent-->
                <StackPanel Grid.Column="2" Margin="10,10,10,5">
                    <Button Margin="0,5,5,5" Command="{Binding AddCommand}" Width="75">Add</Button>
                    <Button Margin="0,5,5,5" Content="Edit" Command="{Binding EditCommand}" Width="75"/>
                    <Button Margin="0,5,5,5" Content="Delete" Command="{Binding DeleteCommand}" Width="75"/>
                    <Button Margin="0,5,5,5" Content="Save" Command="{Binding SaveCommand}" Width="75"/>
                    <Button Margin="0,5,5,5" Content="Cancel" Command="{Binding CancelCommand}" Width="75"/>
                </StackPanel>

                <!--bouton add edit delete save cancel enfant droite du grid-->


                <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,10,10,5" Name="nav" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                    <Button Name="btnFirst" Command="{Binding FirstCommand}" Content="|◄"  Style="{StaticResource NavButton}"/>
                    <Button Name="btnPrev" Command="{Binding PrevCommand}"  Content="◄"  Style="{StaticResource NavButton}"/>
                    <Button Name="btnNext"  Command="{Binding NextCommand}" Content="►"  Style="{StaticResource NavButton}"/>
                    <Button Name="btnLast" Command="{Binding LastCommand}" Content="►|"  Style="{StaticResource NavButton}"/>
                </StackPanel>




                <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal">
                    <GroupBox Header="On pouvait enlever Épaisseur de la bordure (0 à 10)">
                        <Border x:Name="PreviewPanel"
                         Margin="0,12,0,0"
                        Padding="16"
                        CornerRadius="8"

                            Background="CornflowerBlue"
                        BorderBrush="Red"
BorderThickness="{Binding ElementName=ThicknessSlider, Path=Value, StringFormat={}{0}}">


                            <Slider x:Name="ThicknessSlider"
        Minimum="0" Maximum="10" Value="2"
        TickFrequency="1" IsSnapToTickEnabled="True"
        Width="220"/>
                        </Border>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </Grid>
        <!--grande ligne au bas sinon on ne voit pas le bas de l'écran-->

    </Grid>

</UserControl>
